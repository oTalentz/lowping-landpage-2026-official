{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/Admin/index.html"
    },
    {
      "source": "/admin/",
      "destination": "/Admin/index.html"
    },
    {
      "source": "/admin/code",
      "destination": "/Admin/code.html"
    },
    {
      "source": "/admin/code/",
      "destination": "/Admin/code.html"
    }
  ]
}
