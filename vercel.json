{
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/Admin",
      "destination": "/admin",
      "permanent": true
    },
    {
      "source": "/Admin/",
      "destination": "/admin/",
      "permanent": true
    },
    {
      "source": "/Admin/code",
      "destination": "/admin/code",
      "permanent": true
    },
    {
      "source": "/Admin/code/",
      "destination": "/admin/code/",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/admin(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        },
        {
          "key": "Pragma",
          "value": "no-cache"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        },
        {
          "key": "Referrer-Policy",
          "value": "no-referrer"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; frame-ancestors 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tailwindcss.com https://cdn.quilljs.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.quilljs.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://cdn.quilljs.com"
        }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, no-cache, must-revalidate"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow, noarchive"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/Admin/index.html"
    },
    {
      "source": "/admin/",
      "destination": "/Admin/index.html"
    },
    {
      "source": "/admin/code",
      "destination": "/Admin/code.html"
    },
    {
      "source": "/admin/code/",
      "destination": "/Admin/code.html"
    },
    {
      "source": "/privacidade",
      "destination": "/Privacidade/index.html"
    },
    {
      "source": "/privacidade/",
      "destination": "/Privacidade/index.html"
    },
    {
      "source": "/politica-de-privacidade",
      "destination": "/Privacidade/index.html"
    },
    {
      "source": "/politica-de-privacidade/",
      "destination": "/Privacidade/index.html"
    },
    {
      "source": "/termos",
      "destination": "/Termos/index.html"
    },
    {
      "source": "/termos/",
      "destination": "/Termos/index.html"
    },
    {
      "source": "/contato",
      "destination": "/Contato/index.html"
    },
    {
      "source": "/contato/",
      "destination": "/Contato/index.html"
    }
  ]
}
